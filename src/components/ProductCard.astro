---
import type { Product } from "../data/products";
import { BS_RATE, WHATSAPP_NUMBER } from "../config";

interface Props {
  product: Product;
}
const { product } = Astro.props;

const bsPrice = (product.price * BS_RATE).toLocaleString("es-VE", {
  maximumFractionDigits: 0,
});

const outOfStock = product.stock === 0;
const lowStock = product.stock > 0 && product.stock <= 2;

const waMessage = encodeURIComponent(
  `Hola! Me interesa la franela "${product.name}" ($${product.price}). ¿Está disponible?`
);
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${waMessage}`;
---

<article
  class="group relative flex flex-col overflow-hidden rounded-lg bg-card transition-shadow hover:shadow-xl hover:shadow-ink/10"
  data-brand={product.brand}
>
  <div class="relative aspect-[4/5] overflow-hidden bg-card">
    <img
      src={product.img}
      alt={product.name}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
    />

    <span
      class:list={[
        "absolute left-3 top-3 rounded-full px-2.5 py-1 font-mono text-[10px] font-semibold uppercase tracking-wide",
        outOfStock
          ? "bg-cream text-ink"
          : lowStock
            ? "bg-red-drape text-cream"
            : "bg-ink/85 text-cream",
      ]}
    >
      {outOfStock ? "Agotado" : lowStock ? `¡Últimas ${product.stock}!` : `${product.stock} disp.`}
    </span>

    {outOfStock && (
      <span class="absolute inset-0 bg-ink/45 backdrop-blur-[1px]"></span>
    )}
  </div>

  <div class="flex flex-col gap-2 border-t border-ink/10 p-4">
    <h3 class="text-sm font-semibold leading-snug text-ink">{product.name}</h3>

    <div class="flex items-end justify-between">
      <div>
        <p class="font-mono text-xl font-bold leading-none text-ink">${product.price}</p>
        <p class="mt-1 font-mono text-xs font-medium text-ink/60">≈ Bs {bsPrice}</p>
      </div>
    </div>

    {outOfStock ? (
      <button
        disabled
        class="mt-1 cursor-not-allowed rounded-full bg-ink/20 px-4 py-2 text-center text-xs font-semibold text-ink-soft"
      >
        Sin stock
      </button>
    ) : (
      <a
        href={waLink}
        target="_blank"
        rel="noopener"
        class="mt-1 flex items-center justify-center gap-2 rounded-full bg-ink px-4 py-2 text-xs font-semibold text-cream transition-colors hover:bg-red-drape"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5">
          <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.29-1.39a9.9 9.9 0 0 0 4.75 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2"></path>
        </svg>
        Pedir por WhatsApp
      </a>
    )}
  </div>
</article>
