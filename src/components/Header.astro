---
import { SITE } from "../config";
---

<header class="sticky top-4 z-50 px-4 sm:px-6">
  <div
    class="mx-auto flex max-w-5xl items-center justify-between rounded-full bg-ink px-5 py-3 text-cream shadow-lg shadow-ink/20">
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src="/images/dp-logo.png" alt={SITE.name} class="h-6 w-auto" />
      <span class="font-display text-sm tracking-wide">{SITE.name}</span>
    </a>

    <nav class="hidden sm:flex items-center gap-6 text-sm font-medium">
      <a href="#catalogo" class="hover:text-red-drape transition-colors">Catálogo</a>
      <a href="#como-comprar" class="hover:text-red-drape transition-colors">Cómo comprar</a>
    </nav>

    <a
      href="#catalogo"
      class="rounded-full bg-cream px-4 py-2 text-xs font-semibold text-ink transition-colors hover:bg-red-drape hover:text-cream">
      Contacto
    </a>
  </div>
</header>
